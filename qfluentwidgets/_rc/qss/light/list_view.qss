ListView,
ListWidget {
    background: transparent;
    outline: none;
    border: none;
    selection-background-color: transparent;
    alternate-background-color: transparent;
    padding-left: 4px;
    padding-right: 4px;
}

ListView::item,
ListWidget::item {
    background: transparent;
    border: 0px;
    padding-left: 11px;
    padding-right: 11px;
    height: 35px;
}


ListView::indicator,
ListWidget::indicator {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    border: none;
    background-color: transparent;
    margin-right: 4px;
}

RoundListView,
RoundListWidget {
    background: transparent;
    outline: none;
    border: none;
    selection-background-color: transparent;
    alternate-background-color: transparent;
    padding-left: 4px;
    padding-right: 4px;
}

RoundListView::item,
RoundListWidget::item {
    background: rgba(0, 0, 0, 0.015);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 5px;
    padding-left: 16px;
    padding-right: 11px;
    height: 42px;
}

RoundListView::item:hover,
RoundListWidget::item:hover {
    background: rgba(0, 0, 0, 0.01);
    border: 1px solid rgba(0, 0, 0, 0.12);
}

RoundListView::item:selected,
RoundListWidget::item:selected {
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid --ThemeColorPrimary;
}

TransparentRoundListView::item,
TransparentRoundListWidget::item {
    background: transparent;
    border: transparent;
    border-radius: 5px;
    padding-left: 16px;
    padding-right: 11px;
    height: 42px;
}

TransparentRoundListView::item:hover,
TransparentRoundListWidget::item:hover {
    background: rgba(0, 0, 0, 0.01);
    border: 1px solid rgba(0, 0, 0, 0.12);
}

TransparentRoundListView::item:selected,
TransparentRoundListWidget::item:selected {
    background: transparent;
    border: 1px solid --ThemeColorPrimary;
}

CategoryCardListView::item,
CategoryCardListWidget::item {
    background: rgba(0, 0, 0, 0.015);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 5px;
    padding-left: 16px;
    padding-right: 11px;
    height: 42px;
}

CategoryCardListView::item:hover,
CategoryCardListWidget::item:hover {
    background: rgba(0, 0, 0, 0.01);
    border: 1px solid rgba(0, 0, 0, 0.12);
}

CategoryCardListView::item:selected,
CategoryCardListWidget::item:selected {
    background: rgba(0, 0, 0, 0.015);
    border: 1px solid --ThemeColorPrimary;
}
